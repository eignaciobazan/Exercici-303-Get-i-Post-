<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    {{> header}}
    <title>{{common.common.title}}</title>
</head>
<body>
    <section class="texto">
    
    </section>
    <section class="orden">
        <h1>15 primeras peliculas</h1>
        <ul>
            {{#each film}}
                <li>
                    <strong>{{title}} - {{description}} - {{rating}} - {{replacement_cost}} - {{special_features}}</strong>
                </li>
            {{/each}}
        </ul>
    </section>
    <section class="orden">
        <h1>lista de 15 primeros actores</h1>
        <ul>
            {{#each film}}
            <li>
                <strong>{{actor}}</strong>
            </li>
            
            {{/each}}
        </ul>
    </section>

    <main class="container">
    <h1>Afegir nou curs</h1>

    <form method="POST" action="/create" class="form-grid">
      <input type="hidden" name="table" value="film"/>

      <label for="title">Nombre de la pelicula</label>
      <input type="text" id="title" name="title" pattern="[A-Za-z0-9\s:\-']{1,100}" required>

      <label for="description">description</label>
      <input type="text" id="description" name="description" pattern="[A-Za-z0-9\s:\-']{1,100}" required>

      <label for="rating">rating</label>
      <select id="rating" name="Rating" required>
        <option value="">Selecciona una opción</option>
        <option value="PG">PG</option>
        <option value="G">G</option>
        <option value="NC-17">NC-17</option>
        <option value="PG-13">PG-13</option>
        <option value="R">R</option>
      </select>

      <label for="replacement_cost">replacement_cost</label>
      <input type="number" id="replacement_cost" name="replacement_cost" required>

      <label for="special_features">special_features</label>
        <select id="special_features" name="special_features" required>
        <option value="">Selecciona una opción</option>
        <option value="trailers">Trailers</option>
        <option value="commentary">Commentary</option>
        <option value="deleted_scenes">Deleted Scenes</option>
        <option value="behind_the_scenes">Behind the Scenes</option>
        </select>
      <button type="submit">Afegir Movie</button>
    </form>
  </main>
 <main class="container">
  <h1>Editar película</h1>

  <form method="POST" action="/update/{{movie.film_id}}" class="form-grid">

    <label for="title">Nombre de la película</label>
    <input type="text" id="title" name="title" value="{{movie.title}}" required>

    <label for="description">Descripción</label>
    <input type="text" id="description" name="description" value="{{movie.description}}" required>

    <label for="rating">Rating</label>
    <select id="rating" name="rating" required>
      <option value="G" {{#if (eq movie.rating "G")}}selected{{/if}}>G</option>
      <option value="PG" {{#if (eq movie.rating "PG")}}selected{{/if}}>PG</option>
      <option value="PG-13" {{#if (eq movie.rating "PG-13")}}selected{{/if}}>PG-13</option>
      <option value="R" {{#if (eq movie.rating "R")}}selected{{/if}}>R</option>
      <option value="NC-17" {{#if (eq movie.rating "NC-17")}}selected{{/if}}>NC-17</option>
    </select>

    <label for="replacement_cost">Replacement Cost</label>
    <input type="number" id="replacement_cost" name="replacement_cost" value="{{movie.replacement_cost}}" required>

    <label for="special_features">Special Features</label>
    <select id="special_features" name="special_features" required>
      <option value="trailers" {{#if (eq movie.special_features "trailers")}}selected{{/if}}>Trailers</option>
      <option value="commentary" {{#if (eq movie.special_features "commentary")}}selected{{/if}}>Commentary</option>
      <option value="deleted_scenes" {{#if (eq movie.special_features "deleted_scenes")}}selected{{/if}}>Deleted Scenes</option>
      <option value="behind_the_scenes" {{#if (eq movie.special_features "behind_the_scenes")}}selected{{/if}}>Behind the Scenes</option>
    </select>

    <button type="submit">Guardar cambios</button>
  </form>
</main>

    
        
    
</body>
</html>