<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    {{> header}}
    <title>{{common.common.title}}</title>
</head>
<body>
    <section class="texto">
    
    </section>
    <section class="orden">
        <h1>15 primeras peliculas</h1>
        <ul>
            {{#each film}}
                <li>
                    <strong>{{title}} - {{description}} - {{rating}} - {{replacement_cost}} - {{special_features}}</strong>
                </li>
            {{/each}}
        </ul>
    </section>
    <section class="orden">
        <h1>lista de 15 primeros actores</h1>
        <ul>
            {{#each film}}
            <li>
                <strong>{{actor}}</strong>
            </li>
            
            {{/each}}
        </ul>
    </section>

    <main class="container">
    <h1>Agregar nueva película</h1>

    <form method="POST" action="/create" class="form-grid">
      <input type="hidden" name="table" value="film"/>

      <label for="title">Nombre de la pelicula</label>
      <input type="text" id="title" name="title" pattern="[A-Za-z0-9\s:\-']{1,100}" required>

      <label for="description">description</label>
      <input type="text" id="description" name="description" pattern="[A-Za-z0-9\s:\-']{1,100}" required>

      <label for="rating">rating</label>
      <select id="rating" name="rating" required>
        <option value="">Selecciona una opción</option>
        <option value="PG">PG</option>
        <option value="G">G</option>
        <option value="NC-17">NC-17</option>
        <option value="PG-13">PG-13</option>
        <option value="R">R</option>
      </select>

      <label for="replacement_cost">replacement_cost</label>
      <input type="number" id="replacement_cost" name="replacement_cost" min="0" max="999.99" step="0.01" required>

      <label for="special_features">special_features</label>
        <select id="special_features" name="special_features" required>
        <option value="">Selecciona una opción</option>
        <option value="Trailers">Trailers</option>
        <option value="Commentaries">Commentaries</option>
        <option value="Deleted scenes">Deleted Scenes</option>
        <option value="Behind the scenes">Behind the Scenes</option>
        </select>
      <button type="submit">Afegir Movie</button>
    </form>
  </main>
 
 <main class="container">
  <h1>Actualizar Película</h1>

  <form method="POST" action="/update" class="form-grid">
    <input type="hidden" name="table" value="film"/>
    
    <label for="film_id">ID de la Película (Obligatorio)</label>
    <input type="number" id="film_id" name="film_id" required>

    <label for="title">Nombre de la pelicula</label>
    <input type="text" id="title" name="title" pattern="[A-Za-z0-9\s:\-']{1,100}" required>

    <label for="description">description</label>
    <input type="text" id="description" name="description" pattern="[A-Za-z0-9\s:\-']{1,100}" required>

    <label for="rating">rating</label>
    <select id="rating" name="Rating" required>
      <option value="">Selecciona una opción</option>
      <option value="PG">PG</option>
      <option value="G">G</option>
      <option value="NC-17">NC-17</option>
      <option value="PG-13">PG-13</option>
      <option value="R">R</option>
    </select>

    <label for="replacement_cost">replacement_cost</label>
    <input type="number" id="replacement_cost" name="replacement_cost" required>

    <label for="special_features">special_features</label>
    <select id="special_features" name="special_features" required>
      <option value="">Selecciona una opción</option>
      <option value="Trailers">Trailers</option>
      <option value="Commentaries">Commentaries</option>
      <option value="Deleted cenes">Deleted Scenes</option>
      <option value="behind the cenes">Behind the Scenes</option>
    </select>
    
    <button type="submit">Actualizar Movie</button>
  </form>
</main> 

<main class="container">
  <h1>Eliminar Película</h1>
  <p>Introduce el ID de la película que deseas borrar permanentemente.</p>

  <form method="POST" action="/delete" onsubmit="return confirm('¿Estás seguro de que quieres eliminar esta película?');">
    <input type="hidden" name="table" value="film"/>
    
    <label for="film_id">ID de la Película:</label>
    <input type="number" id="film_id" name="film_id" required> 

    <button type="submit" style="background-color: red; color: white;">
      Eliminar Película
    </button>
  </form>
</main>


    
        
    
</body>
</html>